# VulnScout Pro Environment Variables (Example)

# ── App Settings ──
VULNSCOUT_ENVIRONMENT=development
VULNSCOUT_DEBUG=true
VULNSCOUT_SECRET_KEY=generate_a_secure_token_with_secrets_module
VULNSCOUT_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Server Settings ──
VULNSCOUT_HOST=0.0.0.0
VULNSCOUT_PORT=8000
VULNSCOUT_TLS_ENABLED=false

# ── Auth & Security ──
VULNSCOUT_TOTP_REQUIRED=false
VULNSCOUT_SESSION_EXPIRE_MIN=60

# ── EA Configuration ──
VULNSCOUT_EA_CONTEXT_ENABLED=true
VULNSCOUT_TIMEZONE=Africa/Kampala
VULNSCOUT_COMPANY_NAME=VulnScout Pro

# ── Storage ──
VULNSCOUT_DATA_DIR=./data
VULNSCOUT_LOG_LEVEL=INFO
